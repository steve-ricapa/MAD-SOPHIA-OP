# Wazuh Indexer (OpenSearch)
WAZUH_INDEXER_HOST=https://your-wazuh-indexer:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=admin
WAZUH_INDEXER_VERIFY_TLS=False

# Wazuh Server API
WAZUH_API_HOST=https://your-wazuh-server:55000
WAZUH_API_USER=wazuh_api_user
WAZUH_API_PASSWORD=wazuh_api_password
WAZUH_API_VERIFY_TLS=False

# Backend Integration
TXDXAI_INGEST_URL=https://your-backend.com/api/ingest
TXDXAI_COMPANY_ID=9
TXDXAI_API_KEY_WAZUH=your_api_key_here

# Agent Configuration
# Examples per client: 30 (real-time), 900 (15m), 3600 (1h)
POLL_INTERVAL_ALERTS=30
POLL_INTERVAL_AGENTS=60
INITIAL_LOOKBACK_HOURS=2
ALERT_BATCH_SIZE=500
RETRY_FAILED_INTERVAL_SECONDS=30
MIN_RULE_LEVEL=7
DEDUP_RETENTION_DAYS=7
HEARTBEAT_EMPTY_CYCLES=6
SEND_HEARTBEAT=false
CHECKPOINT_FILE=state/agent_state.db
LOG_LEVEL=INFO
DRY_RUN=false
NON_RETRYABLE_BACKOFF_SECONDS=300

# Startup prechecks menu
STARTUP_MENU_ENABLED=true
STARTUP_MENU_DEFAULT_OPTION=1
STARTUP_REQUIRE_ALL_TESTS=true

# Artifacts
ARTIFACTS_DIR=artifacts

# Observability
HEALTH_CHECK_PORT=8080
