# OpenVAS backend delivery
OPENVAS_OUTPUT_MODE=http
TXDXAI_INGEST_URL=https://xvwg3cvl6b.execute-api.us-east-1.amazonaws.com/scans/upload-url
TXDXAI_TENANT_ID=1
TXDXAI_COMPANY_ID=1
TXDXAI_API_KEY_OPENVAS=replace_me
BACKEND_TLS_VERIFY=true

# OpenVAS/GVM source
OPENVAS_COLLECTOR=simulated
GVM_TRANSPORT=tls
GVM_HOST=127.0.0.1
GVM_PORT=9390
GVM_USERNAME=admin
GVM_PASSWORD=replace_me

# Runtime
OPENVAS_POLL_SECONDS=10
OPENVAS_FORCE_SEND_EVERY_CYCLES=6
OPENVAS_SNAPSHOT_ALWAYS_SEND=false
OPENVAS_DETAIL_LEVEL=findings
MAD_VERSION=2.3.0
OPENVAS_INTEGRATION_VERSION=1.0.0
SOURCE=mad-collector
