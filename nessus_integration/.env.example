# Nessus source
NESSUS_BASE_URL=https://127.0.0.1:8834
NESSUS_ACCESS_KEY=replace_with_access_key
NESSUS_SECRET_KEY=replace_with_secret_key
NESSUS_VERIFY_SSL=false
NESSUS_MAX_SCANS_PER_CYCLE=5
# Optional filters (comma-separated IDs)
NESSUS_SCAN_IDS=
NESSUS_FOLDER_ID=

# Agent runtime
POLL_INTERVAL_SECONDS=60
FORCE_SEND_EVERY_CYCLES=10
INCLUDE_ALL_FINDINGS=true
QUEUE_ENABLED=true
QUEUE_DIR=queue
QUEUE_FLUSH_MAX=20
REQUEST_TIMEOUT=30
HTTP_RETRIES=3
BACKOFF_SECONDS=5
RAW_SNAPSHOT_PATH=raw_scans_snapshot.json
EVENT_TYPE=vuln_scan_report

# Backend target
OUTPUT_MODE=stdout
TXDXAI_INGEST_URL=https://your-backend.example.com/api/scans/ingest
TXDXAI_COMPANY_ID=1
TXDXAI_API_KEY_NESSUS=replace_with_backend_api_key
SCANNER_TYPE=nessus
