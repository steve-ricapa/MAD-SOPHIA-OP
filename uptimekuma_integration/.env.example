# Uptime Kuma source
UPTIME_KUMA_URL=https://your-uptime-kuma.example.com
UPTIME_KUMA_METRICS_PATH=/metrics
UPTIME_KUMA_DB_PATH=/data/uptime-kuma/kuma.db

# Option A: basic auth (disable API Keys in Uptime Kuma)
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=change_me

# Option B: API keys enabled in Uptime Kuma
# UPTIME_KUMA_API_KEY_ID=1
# UPTIME_KUMA_API_KEY=your_secret_api_key

# Agent runtime
POLL_INTERVAL_SECONDS=15
FORCE_SEND_EVERY_CYCLES=6
INCLUDE_ALL_MONITORS=false
INCLUDE_EXTENDED_FIELDS=false
QUEUE_ENABLED=true
QUEUE_DIR=queue
QUEUE_FLUSH_MAX=20
REQUEST_TIMEOUT=30
HTTP_RETRIES=3
BACKOFF_SECONDS=5
VERIFY_SSL=true
RAW_SNAPSHOT_PATH=raw_monitors_snapshot.json
EVENT_TYPE=vuln_scan_report

# Version info (metadata in payload)
MAD_VERSION=2.3.0
UPTIMEKUMA_INTEGRATION_VERSION=1.0.0
SOURCE=mad-collector

# Backend target
OUTPUT_MODE=stdout
TXDXAI_INGEST_URL=https://your-backend.example.com/ingest
TXDXAI_COMPANY_ID=1
TXDXAI_API_KEY_UPTIMEKUMA=replace_me
SCANNER_TYPE=uptime_kuma
