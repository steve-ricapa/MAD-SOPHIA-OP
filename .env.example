# ============================================================
# ENV GENERAL EXAMPLE - MAD-SOPHIA-OP
# ============================================================
# Este archivo SI se puede subir al repo.
# No pongas secretos reales aqui.
#
# MODO RECOMENDADO:
# - Usa un solo `.env` en la raiz.
# - Ejecuta con `docker run --env-file .env ...`.
# - Controla intervalos/modo por variables prefijadas (WAZUH_*, OPENVAS_*, etc.).
# - Evita colisiones entre integraciones usando prefijos por agente.
# ============================================================

# ============================================================
# VARIABLES PREFIJADAS POR INTEGRACION
# ============================================================
# Estas variables evitan colisiones entre integraciones en un .env unico
# y permiten ajustar lapsos/modo por servicio sin tocar codigo.

# Orquestador interno (app.py)
# all = todos | lista CSV: wazuh,zabbix,openvas,insightvm,uptimekuma,nessus
MAD_AGENTS=all
# Existencia por cliente (true=existe y se prueba/levanta, false=se omite)
MAD_HAS_WAZUH=true
MAD_HAS_ZABBIX=true
MAD_HAS_OPENVAS=true
MAD_HAS_INSIGHTVM=true
MAD_HAS_UPTIMEKUMA=true
MAD_HAS_NESSUS=true
MAD_RESTART_ON_FAILURE=true
MAD_RESTART_DELAY_SECONDS=5
MAD_STARTUP_MENU_ENABLED=true
MAD_STARTUP_MENU_DEFAULT_OPTION=1
MAD_STARTUP_REQUIRE_ALL_TESTS=true
MAD_STARTUP_TEST_TIMEOUT_SECONDS=3

# ---------------------------
# WAZUH (prefijado)
# ---------------------------
WAZUH_OUTPUT_MODE=all
WAZUH_POLL_INTERVAL_ALERTS=60
WAZUH_POLL_INTERVAL_AGENTS=600
WAZUH_RETRY_FAILED_INTERVAL_SECONDS=60
WAZUH_HEARTBEAT_EMPTY_CYCLES=10
WAZUH_SEND_HEARTBEAT=false
WAZUH_MIN_RULE_LEVEL=7
WAZUH_CHECKPOINT_FILE=state/agent_state.db
WAZUH_ARTIFACTS_DIR=artifacts
WAZUH_LOG_LEVEL=INFO
WAZUH_HEALTH_HOST_PORT=18080

# ---------------------------
# ZABBIX (prefijado)
# ---------------------------
ZABBIX_OUTPUT_MODE=all
ZABBIX_INTERVAL=180
ZABBIX_HOURS=24
ZABBIX_PROBLEMS_LIMIT=2000
ZABBIX_TRIGGERS_LIMIT=5000
ZABBIX_EVENTS_LIMIT=2000
ZABBIX_INCLUDE_EVENTS=false

# ---------------------------
# OPENVAS (prefijado)
# ---------------------------
OPENVAS_OUTPUT_MODE=http
# gmp = real | simulated = demo/lab
OPENVAS_COLLECTOR=gmp
OPENVAS_POLL_SECONDS=600
OPENVAS_STATE_PATH=./state.json
OPENVAS_DETAIL_LEVEL=findings

# ---------------------------
# INSIGHTVM (prefijado)
# ---------------------------
INSIGHTVM_OUTPUT_MODE=all
INSIGHTVM_INTERVAL_SECONDS=600
INSIGHTVM_STATE_FILE=state.json
INSIGHTVM_TIMEOUT=30

# ---------------------------
# UPTIME KUMA (prefijado)
# ---------------------------
UPTIME_OUTPUT_MODE=all
UPTIME_SCANNER_TYPE=uptimekuma
UPTIME_POLL_INTERVAL_SECONDS=120
UPTIME_FORCE_SEND_EVERY_CYCLES=15
UPTIME_INCLUDE_ALL_MONITORS=false
UPTIME_INCLUDE_EXTENDED_FIELDS=false

# ---------------------------
# NESSUS (prefijado)
# ---------------------------
NESSUS_OUTPUT_MODE=all
NESSUS_SCANNER_TYPE=nessus
NESSUS_POLL_INTERVAL_SECONDS=600
NESSUS_FORCE_SEND_EVERY_CYCLES=6
NESSUS_MAX_SCANS_PER_CYCLE=5


# ============================================================
# 1) WAZUH INTEGRATION
# Ruta: wazuh_integration/.env
# ============================================================
# Estas variables se usan al ejecutar wazuh directamente.
# Wazuh Indexer (OpenSearch)
WAZUH_INDEXER_HOST=https://YOUR_WAZUH_INDEXER_HOST:9200
WAZUH_INDEXER_USER=YOUR_WAZUH_INDEXER_USER
WAZUH_INDEXER_PASSWORD=YOUR_WAZUH_INDEXER_PASSWORD
WAZUH_INDEXER_VERIFY_TLS=false

# Wazuh Server API
WAZUH_API_HOST=https://YOUR_WAZUH_API_HOST:55000
WAZUH_API_USER=YOUR_WAZUH_API_USER
WAZUH_API_PASSWORD=YOUR_WAZUH_API_PASSWORD
WAZUH_API_VERIFY_TLS=false

# Wazuh-WUI API Credentials (opcional)
WAZUH_WUI_USER=YOUR_WAZUH_WUI_USER
WAZUH_WUI_PASSWORD=YOUR_WAZUH_WUI_PASSWORD

# Backend Integration
TXDXAI_INGEST_URL=https://YOUR_BACKEND_HOST/api/scans/ingest
TXDXAI_COMPANY_ID=YOUR_TXDXAI_COMPANY_ID
TXDXAI_API_KEY_WAZUH=YOUR_TXDXAI_API_KEY

# Agent Configuration
POLL_INTERVAL_ALERTS=30
POLL_INTERVAL_AGENTS=60
MIN_RULE_LEVEL=7
CHECKPOINT_FILE=state/agent_state.db
LOG_LEVEL=INFO
INITIAL_LOOKBACK_HOURS=2
ALERT_BATCH_SIZE=500
RETRY_FAILED_INTERVAL_SECONDS=30
DEDUP_RETENTION_DAYS=7
HEARTBEAT_EMPTY_CYCLES=6
SEND_HEARTBEAT=false
ARTIFACTS_DIR=artifacts

# Observability
HEALTH_CHECK_PORT=8080

# Debug / Development
DRY_RUN=false


# ============================================================
# 2) ZABBIX INTEGRATION
# Ruta: zabix_integration/.env
# ============================================================
# Estas variables se usan al ejecutar zabbix directamente.
# Zabbix Source
ZABBIX_API_URL=http://YOUR_ZABBIX_HOST/zabbix/api_jsonrpc.php
ZABBIX_USER=YOUR_ZABBIX_USER
ZABBIX_PASS=YOUR_ZABBIX_PASSWORD
HOURS=24
INTERVAL=60
VERIFY_SSL=false
REQUEST_TIMEOUT=30
HTTP_RETRIES=3
BACKOFF_SECONDS=5
PROBLEMS_LIMIT=2000
TRIGGERS_LIMIT=5000
EVENTS_LIMIT=2000
INCLUDE_EVENTS=false

# TxDxAI (Backend)
# Cambia a 'webhook' para enviar solo backend o 'all' para consola + backend.
OUTPUT_MODE=all
TXDXAI_INGEST_URL=https://YOUR_BACKEND_HOST/api/scans/ingest
TXDXAI_COMPANY_ID=YOUR_TXDXAI_COMPANY_ID
TXDXAI_API_KEY_ZABBIX=YOUR_TXDXAI_API_KEY

# Estado local
STATE_FILE=state.json
DEBUG_REPORT_PATH=debug_report.json
LAST_PAYLOAD_PATH=last_payload_sent.json


# ============================================================
# 3) OPENVAS INTEGRATION
# Ruta: openVAS_integration/.env
# ============================================================
# Estas variables se usan al ejecutar openVAS directamente.
# Agent configuration
OUTPUT_MODE=http
# gmp = real | simulated = demo/lab
COLLECTOR=gmp
POLL_SECONDS=10
STATE_PATH=./state.json
META_MAX_KB=900
PYTHONDONTWRITEBYTECODE=1
DETAIL_LEVEL=findings
TOP_N=50
REPORT_MAX_KB=4096
FINDING_TEXT_MAX=300
DEBUG=false
MAX_ERROR_REPEAT=3

# OpenVAS / Greenbone (GVMD)
GVM_SOCKET=/run/gvmd/gvmd.sock
GVM_USERNAME=YOUR_GVM_USER
GVM_PASSWORD=YOUR_GVM_PASSWORD
# GVM_HOST=127.0.0.1
# GVM_PORT=9390

# TxDxAI (Backend)
TXDXAI_INGEST_URL=https://YOUR_BACKEND_HOST/api/scans/ingest
TXDXAI_COMPANY_ID=YOUR_TXDXAI_COMPANY_ID
TXDXAI_API_KEY_OPENVAS=YOUR_TXDXAI_API_KEY
# Si el backend usa self-signed, puedes poner false.
BACKEND_TLS_VERIFY=true


# ============================================================
# 4) INSIGHTVM INTEGRATION
# Ruta: insightVM_integration/.env
# ============================================================
# Estas variables se usan al ejecutar insightVM directamente.
INSIGHTVM_USER=YOUR_INSIGHTVM_USER
INSIGHTVM_PASSWORD=YOUR_INSIGHTVM_PASSWORD
INSIGHTVM_BASE_URL=https://YOUR_INSIGHTVM_HOST:3780/api/3
INSIGHTVM_VERIFY_SSL=false

# TxDxAI (Backend)
TXDXAI_INGEST_URL=https://YOUR_BACKEND_HOST/api/scans/ingest
TXDXAI_COMPANY_ID=YOUR_TXDXAI_COMPANY_ID
TXDXAI_API_KEY_INSIGHTVM=YOUR_TXDXAI_API_KEY

# Estado local
STATE_FILE=state.json


# ============================================================
# 5) UPTIME KUMA INTEGRATION
# Ruta: uptimekuma_integration/.env
# ============================================================
# Estas variables se usan al ejecutar uptimekuma directamente.
# Uptime Kuma source
UPTIME_KUMA_URL=https://YOUR_UPTIME_KUMA_HOST
UPTIME_KUMA_METRICS_PATH=/metrics
UPTIME_KUMA_DB_PATH=/data/uptime-kuma/kuma.db

# Option A: basic auth
UPTIME_KUMA_USERNAME=YOUR_UPTIME_KUMA_USER
UPTIME_KUMA_PASSWORD=YOUR_UPTIME_KUMA_PASSWORD

# Option B: API keys enabled in Uptime Kuma
# UPTIME_KUMA_API_KEY_ID=1
# UPTIME_KUMA_API_KEY=YOUR_UPTIME_KUMA_API_KEY

# Agent runtime
POLL_INTERVAL_SECONDS=15
FORCE_SEND_EVERY_CYCLES=6
INCLUDE_ALL_MONITORS=true
INCLUDE_EXTENDED_FIELDS=false
QUEUE_ENABLED=true
QUEUE_DIR=queue
QUEUE_FLUSH_MAX=20
REQUEST_TIMEOUT=30
HTTP_RETRIES=3
BACKOFF_SECONDS=5
VERIFY_SSL=true
RAW_SNAPSHOT_PATH=raw_monitors_snapshot.json
EVENT_TYPE=vuln_scan_report

# Backend target
OUTPUT_MODE=stdout
TXDXAI_INGEST_URL=https://YOUR_BACKEND_HOST/api/scans/ingest
TXDXAI_COMPANY_ID=YOUR_TXDXAI_COMPANY_ID
TXDXAI_API_KEY_UPTIMEKUMA=YOUR_TXDXAI_API_KEY
# SCANNER_TYPE local manual (si corres solo uptimekuma_integration/agent.py)
# Se recomienda UPTIME_SCANNER_TYPE para configuracion prefijada.
# Si tu backend antiguo no tiene 'uptimekuma', usa temporalmente 'other'.
SCANNER_TYPE=uptimekuma


# ============================================================
# 6) NESSUS INTEGRATION
# Ruta: nessus_integration/.env
# ============================================================
# Estas variables se usan al ejecutar nessus directamente.
# Nessus source
NESSUS_BASE_URL=https://YOUR_NESSUS_HOST:8834
NESSUS_ACCESS_KEY=YOUR_NESSUS_ACCESS_KEY
NESSUS_SECRET_KEY=YOUR_NESSUS_SECRET_KEY
NESSUS_VERIFY_SSL=false
NESSUS_MAX_SCANS_PER_CYCLE=5
# Opcionales (filtrado)
NESSUS_SCAN_IDS=
NESSUS_FOLDER_ID=

# Agent runtime
POLL_INTERVAL_SECONDS=60
FORCE_SEND_EVERY_CYCLES=10
INCLUDE_ALL_FINDINGS=true
QUEUE_ENABLED=true
QUEUE_DIR=queue
QUEUE_FLUSH_MAX=20
REQUEST_TIMEOUT=30
HTTP_RETRIES=3
BACKOFF_SECONDS=5
RAW_SNAPSHOT_PATH=raw_scans_snapshot.json
EVENT_TYPE=vuln_scan_report

# Backend target
OUTPUT_MODE=all
TXDXAI_INGEST_URL=https://YOUR_BACKEND_HOST/api/scans/ingest
TXDXAI_COMPANY_ID=YOUR_TXDXAI_COMPANY_ID
TXDXAI_API_KEY_NESSUS=YOUR_TXDXAI_API_KEY
# SCANNER_TYPE local manual (si corres solo nessus_integration/main.py)
# Se recomienda NESSUS_SCANNER_TYPE para configuracion prefijada.
SCANNER_TYPE=nessus
