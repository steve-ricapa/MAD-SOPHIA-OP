# =========================
# Zabbix Source
# =========================
ZABBIX_API_URL=https://zabbix.example.com/zabbix/api_jsonrpc.php
ZABBIX_USER=Admin
ZABBIX_PASS=replace_me
HOURS=24
INTERVAL=60
VERIFY_SSL=true
REQUEST_TIMEOUT=30
HTTP_RETRIES=3
BACKOFF_SECONDS=5
PROBLEMS_LIMIT=2000
TRIGGERS_LIMIT=5000
EVENTS_LIMIT=2000
INCLUDE_EVENTS=false

# =========================
# TxDxAI (Backend)
# =========================
OUTPUT_MODE=webhook
TXDXAI_INGEST_URL=https://txdxai-flask.replit.app/api/scans/ingest
TXDXAI_COMPANY_ID=1
TXDXAI_API_KEY_ZABBIX=replace_me

# =========================
# Local State / Debug Files
# =========================
STATE_FILE=state.json
DEBUG_REPORT_PATH=debug_report.json
LAST_PAYLOAD_PATH=last_payload_sent.json
