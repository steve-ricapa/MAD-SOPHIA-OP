# =========================
# InsightVM Source
# =========================
INSIGHTVM_BASE_URL=https://your-insightvm.example.com:3780/api/3
INSIGHTVM_USER=admin
INSIGHTVM_PASSWORD=replace_me
INSIGHTVM_TIMEOUT=30
INSIGHTVM_VERIFY_SSL=false
INSIGHTVM_CA_BUNDLE=

# =========================
# TxDxAI (Backend)
# =========================
TXDXAI_INGEST_URL=https://txdxai-flask.replit.app/api/scans/ingest
TXDXAI_COMPANY_ID=1
TXDXAI_API_KEY_INSIGHTVM=replace_me
BACKEND_VERIFY_SSL=true

# =========================
# Snapshot / Queue
# =========================
FORCE_SEND_EVERY_CYCLES=10
SNAPSHOT_ALWAYS_SEND=false
QUEUE_ENABLED=true
QUEUE_DIR=queue
QUEUE_FLUSH_MAX=20
MAD_VERSION=2.3.0
INSIGHTVM_INTEGRATION_VERSION=1.0.0
SOURCE=mad-collector

# =========================
# Agent Runtime
# =========================
INTERVAL=60
EVENT_TYPE=vuln_scan_report
STATE_FILE=state.json
